{
  "info": {
    "name": "Task Time Tracker API",
    "description": "REST API для учета времени сотрудников",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Разработка API\",\n  \"description\": \"Создать REST-сервис\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Создает новую задачу. Статус автоматически устанавливается в NEW."
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/1",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "1"]
            },
            "description": "Получает задачу по её ID."
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/1/status?status=IN_PROGRESS",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "1", "status"],
              "query": [
                { "key": "status", "value": "IN_PROGRESS", "description": "Допустимые значения: NEW, IN_PROGRESS, DONE" }
              ]
            },
            "description": "Изменяет статус задачи."
          }
        }
      ]
    },
    {
      "name": "TimeRecords",
      "item": [
        {
          "name": "Create Time Record",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": 1,\n  \"taskId\": 1,\n  \"startTime\": \"2026-04-30T09:00:00\",\n  \"endTime\": \"2026-04-30T11:30:00\",\n  \"description\": \"Написание контроллера\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/records",
              "host": ["{{baseUrl}}"],
              "path": ["records"]
            },
            "description": "Создает запись о затраченном времени. taskId должен ссылаться на существующую задачу."
          }
        },
        {
          "name": "Get Records by Period",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/records/period?employeeId=1&start=2026-04-30T00:00:00&end=2026-04-30T23:59:59",
              "host": ["{{baseUrl}}"],
              "path": ["records", "period"],
              "query": [
                { "key": "employeeId", "value": "1" },
                { "key": "start", "value": "2026-04-30T00:00:00", "description": "Начало периода (ISO 8601)" },
                { "key": "end", "value": "2026-04-30T23:59:59", "description": "Конец периода (ISO 8601)" }
              ]
            },
            "description": "Получает записи времени сотрудника за указанный период."
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ping",
          "host": ["{{baseUrl}}"],
          "path": ["ping"]
        },
        "description": "Проверка работоспособности API."
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}